# MR Newsletter 환경 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요

# ===== AWS SES 이메일 발송 설정 =====
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# 기본 리전 서울인 경우 ap-northeast-2
AWS_REGION=ap-northeast-2
# SES에서 인증받은 발신자 이메일
AWS_SES_SENDER_EMAIL=admin@yourdomain.com

# ===== 네이버 카페 크롤링 (Selenium) =====
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password

# ===== 웹사이트 및 API 설정 =====
SITE_URL=https://yourdomain.com
SITE_TITLE=MR Newsletter
WEB_APP_URL=https://script.google.com/macros/s/xxxx/exec
GAS_API_TOKEN=your_security_token_here
ADMIN_EMAIL=your_email@gmail.com

# ===== GitHub Pages 배포 =====
GITHUB_REPO=your_username/mrnewsletter
GITHUB_TOKEN=your_github_token

# ===== DB 경로 =====
DB_PATH=data/newsletter.db
